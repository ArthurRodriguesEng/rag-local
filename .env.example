POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DEBUG=false
UPLOAD_DIR=uploads

RAG_PROFILE=fast_local
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024

CHAT_PROVIDER=ollama
CHAT_MODEL=llama3.2:3b

OLLAMA_URL=http://localhost:11434

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_LIMIT=3
RETRIEVAL_CANDIDATE_LIMIT=6
# RETRIEVAL_MAX_DISTANCE=0.35
RAG_MAX_CONTEXT_CHARS=3200
RAG_HISTORY_LIMIT=2
RAG_RESPONSE_MODE=concise
RAG_PROMPT_PATH=prompts/internal_assistant.md

RAG_SYSTEM_PROMPT=Você é um assistente de conhecimento local. Responda somente com base no contexto fornecido.
RAG_EMPTY_CONTEXT_MESSAGE=Não encontrei informação suficiente nos documentos.

EMBEDDING_TIMEOUT_SECONDS=60
CHAT_TIMEOUT_SECONDS=120
